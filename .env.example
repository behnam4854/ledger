# Copy this file to .env.local and fill in your values.

# Local development uses SQLite.
DATABASE_URL="file:./dev.db"

# Auth.js v5 — generate with: openssl rand -base64 33
AUTH_SECRET="replace-me-with-openssl-rand-base64-33"
AUTH_URL="http://localhost:3000"

# Vercel production variables (set these in Vercel, not in this file):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# AUTH_SECRET="a-long-random-production-secret"
# AUTH_URL="https://your-project.vercel.app"
