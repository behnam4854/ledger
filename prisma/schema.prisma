// LEDGRS data model — multi-user edition.
//
// All money/quantity fields are decimal STRINGS; arithmetic is done in
// decimal.js (see src/lib/calculations.ts) so there is no float drift.
//
// To deploy on Postgres: change `provider` to "postgresql" and set DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String    // bcrypt hash — never returned to client
  createdAt DateTime  @default(now())

  buys     Buy[]
  sells    Sell[]
  settings Setting[]
  coins    Coin[]
  futuresPositions FuturesPosition[]
}

// Extra assets a user has enabled for their portfolio. The three built-in
// assets (BTC, ETH and XAUT) live in code and do not need database rows.
model Coin {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  name        String
  coingeckoId String
  createdAt   DateTime @default(now())

  @@unique([userId, symbol])
  @@unique([userId, coingeckoId])
  @@index([userId])
}

// Isolated-margin paper futures positions. These never place exchange orders;
// they are marked against the same CoinGecko prices used by the portfolio.
model FuturesPosition {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       String
  side        String    // LONG | SHORT
  leverage    Int
  margin      String    // isolated collateral in USD
  quantity    String    // asset units controlled by the position
  entryPrice  String
  stopLoss    String?
  takeProfit  String?
  status      String    @default("OPEN") // OPEN | CLOSED
  exitPrice   String?
  realizedPnl String?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  @@index([userId, status])
}

model Buy {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet    String
  asset     String
  amount    String   // decimal string — units of the asset
  price     String   // decimal string — USD per unit at purchase
  date      String   // ISO date (YYYY-MM-DD)
  createdAt DateTime @default(now())

  sells Sell[]

  @@index([userId])
  @@index([asset])
}

model Sell {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyId     Int
  buy       Buy      @relation(fields: [buyId], references: [id], onDelete: Cascade)
  amount    String   // decimal string — units sold from the linked buy
  sellPrice String   // decimal string — USD per unit at sale
  sellDate  String   // ISO date (YYYY-MM-DD)
  profit    String   // decimal string — realized P&L in USD
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([buyId])
}

// Daily price history (shared market data, like the live price cache — not
// per-user). One row per asset per calendar day. This is the raw material for
// indicators, signals and backtesting; we back it up from CoinGecko's free
// market_chart endpoint and keep today's row fresh from the live price.
model Candle {
  asset     String
  date      String   // ISO date (YYYY-MM-DD)
  close     String   // decimal string — USD close price for that day
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([asset, date])
  @@index([asset])
}

// Per-user key/value settings (e.g. USD cash balance).
model Setting {
  userId Int
  key    String
  value  String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
}
